[
  {
    "match": "**/*",
    "headers": {
      "Content-Security-Policy": "default-src 'self';script-src 'self' https://esm.sh;connect-src 'self' http://localhost:* http://127.0.0.1:* http://*.localhost:* https://esm.sh https://ic0.app https://*.ic0.app https://icp0.io https://*.icp0.io https://icp-api.io;img-src 'self' data:;style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;style-src-elem 'self' 'unsafe-inline' https://fonts.googleapis.com;font-src 'self' data: https://fonts.gstatic.com;object-src 'none';base-uri 'self';frame-ancestors 'none';form-action 'self';",
      "X-Frame-Options": "DENY",
      "Referrer-Policy": "same-origin",
      "X-Content-Type-Options": "nosniff",
      "X-XSS-Protection": "1; mode=block"
    }
  }
]
